---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getLangFromUrl, useTranslations } from '../../i18n/ui';
import { navItems } from '../../i18n/nav';
import LangToggle from '../ui/LangToggle.astro';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

// Base del home en el idioma actual ('/' o '/en/'), para que los anclas funcionen también desde las páginas de detalle de proyecto.
const home = getRelativeLocaleUrl(lang, '/');
---

<script>
  //Colocar el header con fondo oscuro al hacer scroll
  if (typeof window !== "undefined") {
    window.addEventListener("scroll", () => {
      const header = document.querySelector("header");
      if (window.scrollY > 10) {
        header?.classList.add("bg-neutral-950/30", "backdrop-blur-md", "shadow-md");
      } else {
        header?.classList.remove("bg-neutral-950/30", "backdrop-blur-md", "shadow-md");
      }
    });
  }
</script>

<header class="w-full px-4 py-5 flex justify-between md:justify-around items-center mx-auto fixed top-0 z-50 transition-all duration-300">
  <!-- Foto de perfil -->
  <a href={home}>
    <img
      loading="lazy"
      class="rounded-full size-12"
      src="/fotoPerfil.avif"
      alt={t('header.photoAlt')}
    />
  </a>

  <!-- Menú desktop -->
  <nav class="hidden md:flex flex-row gap-x-10 opacity-80 text-sm">
    {navItems.map(item => (
      <a href={`${home}${item.hash}`} class="text-white hover:underline">{t(item.key)}</a>
    ))}
  </nav>

  <LangToggle />
</header>