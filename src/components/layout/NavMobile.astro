---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getLangFromUrl, useTranslations } from '../../i18n/ui';
import { navItems } from '../../i18n/nav';
import Home from "../../icons/ui/Home.astro"
import UserSuit from "../../icons/ui/UserSuit.astro"
import Briefcase from "../../icons/ui/Briefcase.astro"
import CodeBranch from "../../icons/ui/CodeBranch.astro"
import UserGraduate from "../../icons/ui/UserGraduate.astro"
import Code from "../../icons/ui/Code.astro"

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const home = getRelativeLocaleUrl(lang, '/');

// Cada item de navegación con su icono, en el mismo orden que navItems.
const icons = {
  'nav.home': Home,
  'nav.about': UserSuit,
  'nav.experience': Briefcase,
  'nav.projects': CodeBranch,
  'nav.education': UserGraduate,
  'nav.skills': Code,
};

const items = navItems.map((item, i) => ({
  ...item,
  Icon: icons[item.key],
  first: i === 0,
  last: i === navItems.length - 1,
}));
---

<div class="fixed md:hidden z-50 w-full h-15 max-w-lg -translate-x-1/2 rounded-full bottom-3 left-1/2 bg-neutral-950 bg-[radial-gradient(ellipse_80%_80%_at_50%_-20%,rgba(120,119,198,0.3),rgba(255,255,255,0))] border-gray-600">
    <div class="grid h-full max-w-lg grid-cols-6 mx-auto">
        {items.map(({ hash, key, Icon, first, last }) => (
            <a
                href={`${home}${hash}`}
                aria-label={t(key)}
                class:list={[
                    "inline-flex flex-col items-center justify-center px-3 md:px-5 hover:bg-gray-800 group",
                    first && "rounded-s-full",
                    last && "rounded-e-full",
                ]}
            >
                <Icon class="size-4 md:size-5 text-gray-400 group-hover:text-cyan-700" />
                <span class="sr-only">{t(key)}</span>
            </a>
        ))}
    </div>
</div>