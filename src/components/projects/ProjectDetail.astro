---
import ProjectGallery from '../projects/ProjectGallery.astro';
import ProjectLayout from '../../layouts/ProjectLayout.astro';
import Github from '../../icons/social/Github.astro';
import Tecnologias from '../../components/ui/Tecnologias.astro';
import { tags } from '../../data/tags.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const { project } = Astro.props;

// Los tags llegan como strings desde la colección; aquí se resuelven
// al objeto con nombre, icono y color que espera <Tecnologias />
const projectTags = project.tags.map((key) => tags[key]);
---

<ProjectLayout 
  title={`${project.title} · Joseph Pérez`}
  description={project.description[lang].slice(0, 155)}
>
  <section class="max-w-6xl mx-auto px-4 py-10 mt-20">
    <h1 class="text-white text-3xl md:text-4xl font-bold mb-4">{project.title}</h1>

    <p class="text-base md:text-lg text-gray-400 mb-6">{project.description[lang]}</p>

    {projectTags.length > 0 && <Tecnologias tags={projectTags} />}

    {project.images && project.imagesMobile && (
      <ProjectGallery images={project.images} imagesMobile={project.imagesMobile} />
    )}

    <div class="m-0 mt-8 grid grid-cols-2 sm:flex gap-3 sm:gap-x-5">
      {project.github.map((repo) => (
        <a href={repo.url} target="_blank" rel="noopener" class="text-white bg-[#24292F] focus:ring-4 focus:outline-none font-medium rounded-lg text-sm px-5 py-2.5 text-center inline-flex items-center focus:ring-gray-500 ">
          <Github class="size-5 mr-1"></Github>
          {t('project.viewRepo')} {t(`repo.${repo.name}`)}
        </a>
      ))}
      {project.link && (
        <a href={project.link} target="_blank" rel="noopener" class="text-white bg-gradient-to-r from-blue-500 via-blue-600 to-blue-700 hover:bg-gradient-to-br focus:ring-4 focus:outline-none focus:ring-blue-800 font-medium rounded-lg text-sm px-5 py-2.5 text-center  ">
          {t('project.viewLive')}
        </a>
      )}
    </div>
  </section>
</ProjectLayout>