---
import { getRelativeLocaleUrl } from 'astro:i18n';
import { getLangFromUrl } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const other = lang === 'es' ? 'en' : 'es';

// Ruta actual sin el prefijo de idioma, para enlazar a la misma página
// en el otro idioma en lugar de mandar siempre al home.
const path = Astro.url.pathname.replace(/^\/en(?=\/|$)/, '') || '/';
---

<a
  href={getRelativeLocaleUrl(other, path)}
  hreflang={other}
  aria-label={other === 'en' ? 'Switch to English' : 'Cambiar a español'}
  class="text-white text-sm border border-cyan-800 rounded-full px-3 py-1 opacity-80 hover:opacity-100 hover:bg-white/10 transition"
>
  {other.toUpperCase()}
</a>