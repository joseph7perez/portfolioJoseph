---
import { getCollection } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../../i18n/ui';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const entries = await getCollection('education');

const byType = (type: string) =>
  entries
    .map(({ data }) => data)
    .filter((e) => e.type === type)
    .sort((a, b) => a.order - b.order);

const formal = byType('formal');
const certificados = byType('certificate');
const idiomas = byType('language');
---
<section class="scroll-mt-24 py-2 bg-neutral-950 text-cyan-100">
  <div class="max-w-4xl mx-auto px-3">

    <!-- Educación formal -->
    <div class="space-y-6 mb-12">
      {formal.map((item) => (
        <div class="border-l-4 border-cyan-300 pl-4">
          <h3 class="text-2xl font-semibold">{item.titulo[lang]}</h3>
          <p class="text-sm text-cyan-200">{item.institucion} · {item.date[lang]}</p>
        </div>
      ))}
    </div>

    <!-- Certificados -->
    <h3 class="text-2xl font-bold text-cyan-200 mb-4">{t('education.certificates')}</h3>

    {certificados.map((item) => (
      <div class="group flex flex-col justify-center content-center">
        {item.archivo ? (
          <Fragment>
            <a
              href={item.archivo}
              download
              class="bg-neutral-900 p-4 rounded-lg shadow border border-cyan-900 hover:cursor-pointer hover:bg-neutral-800 transition"
            >
              <p class="text-sm md:text-lg font-semibold">{item.titulo[lang]}</p>
              <p class="text-xs md:text-sm text-cyan-300">{item.institucion} · {item.date[lang]}</p>
            </a>
            <span class="mb-2 text-xs text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center">
              {t('education.download')}
            </span>
          </Fragment>
        ) : (
          <div class="bg-neutral-900 p-4 rounded-lg shadow border border-cyan-900 transition mb-6">
            <p class="text-sm md:text-lg font-semibold">{item.titulo[lang]}</p>
            <p class="text-xs md:text-sm text-cyan-300">{item.institucion} · {item.date[lang]}</p>
          </div>
        )}
      </div>
    ))}

    <!-- Idiomas -->
    <h3 class="text-2xl font-bold mb-2 mt-5 text-cyan-200">{t('education.languages')}</h3>

    {idiomas.map((item) => (
      <div class="group flex flex-col justify-center content-center">
        {item.archivo ? (
          <Fragment>
            <a
              href={item.archivo}
              download
              class="bg-neutral-900 p-4 rounded-lg shadow border border-cyan-900 hover:cursor-pointer hover:bg-neutral-800 transition"
            >
              <p class="text-sm md:text-lg font-semibold">{item.titulo[lang]}</p>
              <p class="text-xs md:text-sm text-cyan-300">{item.institucion} · {item.date[lang]}</p>
            </a>
            <span class="mb-2 text-xs text-white opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center">
              {t('education.download')}
            </span>
          </Fragment>
        ) : (
          <div class="bg-neutral-900 p-4 rounded-lg shadow border border-cyan-900 transition">
            <p class="text-sm md:text-lg font-semibold">{item.titulo[lang]}</p>
            <p class="text-xs md:text-sm text-cyan-300">{item.institucion} · {item.date[lang]}</p>
          </div>
        )}
      </div>
    ))}
  </div>
</section>